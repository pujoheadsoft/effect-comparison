effect Get : int
effect Set : int -> unit

let state_handler init = handler
  | x -> (fun s -> (x, s))
  | effect Get k -> (fun s -> k s s)
  | effect (Set s') k -> (fun _ -> k () s')
  | finally f -> f init
;;

let run_state init action =
  with state_handler init handle
    action ()
;;

let get () = perform Get;;

let put s = perform (Set s);;

let example () =
  let x = get () in
  put (x + 1) ;
  let y = get () in
  (x, y)
;;

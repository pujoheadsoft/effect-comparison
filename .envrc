# Koka 3.2.3 is installed on this machine, but only the v3.2.2 share/lib
# directories are present. These settings keep the local examples and editor
# diagnostics working without changing system directories.
export koka_share_dir=/usr/local/share/koka/v3.2.2
export koka_lib_dir=/usr/local/lib/koka/v3.2.2
export koka_options="--include=$PWD/koka/src ${koka_options:-}"
